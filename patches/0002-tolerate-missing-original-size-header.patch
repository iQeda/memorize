From: iQeda <noreply@iqeda.dev>
Subject: [PATCH 2/3] Tolerate sync responses missing the
 `anki-original-size` header (e.g. AnkiWeb `/upload` plain-text "OK").

Modification by iQeda for the memorize project (https://github.com/iQeda/memorize),
on top of upstream ankitects/anki @ 35b727a. Originally created 2026-04-12,
last updated 2026-04-27.

Per AGPL-3.0-or-later §5(a): this file is a modification of Anki's rslib,
which is Copyright (C) Ankitects Pty Ltd, licensed under AGPL-3.0-or-later.

---
diff --git a/rslib/src/sync/http_client/io_monitor.rs b/rslib/src/sync/http_client/io_monitor.rs
index 602b672dd..064e82649 100644
--- a/rslib/src/sync/http_client/io_monitor.rs
+++ b/rslib/src/sync/http_client/io_monitor.rs
@@ -120,26 +120,55 @@ impl IoMonitor {
                 .await?
                 .error_for_status()?;
             map_redirect_to_error(&resp)?;
+            let resp_status = resp.status();
+            let resp_url = resp.url().to_string();
+            let resp_headers = format!("{:?}", resp.headers());
+            tracing::debug!(
+                status = %resp_status,
+                url = %resp_url,
+                headers = %resp_headers,
+                "sync response"
+            );
             let response_total = resp
                 .headers()
                 .get(&ORIGINAL_SIZE)
                 .and_then(|v| v.to_str().ok())
-                .and_then(|v| v.parse::<u32>().ok())
-                .or_bad_request("missing original size")?;
-            let response_stream = self.wrap_stream(
-                false,
-                response_total,
-                decode_zstd_body_stream_for_client(resp.bytes_stream()),
-            );
-            let mut reader =
-                StreamReader::new(response_stream.map_err(|e| {
-                    std::io::Error::new(ErrorKind::ConnectionAborted, format!("{e}"))
-                }));
-            let mut buf = Vec::with_capacity(response_total as usize);
-            reader
-                .read_to_end(&mut buf)
-                .await
-                .or_http_err(StatusCode::SEE_OTHER, "reading stream")?;
+                .and_then(|v| v.parse::<u32>().ok());
+            let buf = if let Some(total) = response_total {
+                let response_stream = self.wrap_stream(
+                    false,
+                    total,
+                    decode_zstd_body_stream_for_client(resp.bytes_stream()),
+                );
+                let mut reader =
+                    StreamReader::new(response_stream.map_err(|e| {
+                        std::io::Error::new(ErrorKind::ConnectionAborted, format!("{e}"))
+                    }));
+                let mut buf = Vec::with_capacity(total as usize);
+                reader
+                    .read_to_end(&mut buf)
+                    .await
+                    .or_http_err(StatusCode::SEE_OTHER, "reading stream")?;
+                buf
+            } else {
+                // memorize patch: production AnkiWeb's /upload endpoint
+                // returns a small plain-text response ("OK" or an error
+                // message) WITHOUT the anki-original-size header and
+                // WITHOUT zstd encoding. Read the body raw in that case.
+                let body = resp
+                    .bytes()
+                    .await
+                    .or_http_err(StatusCode::SEE_OTHER, "reading raw body")?;
+                let preview =
+                    String::from_utf8_lossy(&body[..body.len().min(200)]).into_owned();
+                tracing::info!(
+                    status = %resp_status,
+                    body_len = body.len(),
+                    body_preview = %preview,
+                    "sync response (no original-size)"
+                );
+                body.to_vec()
+            };
             Ok::<_, HttpError>(buf)
         };
         select! {
